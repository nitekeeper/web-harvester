{"manifest_version":3,"name":"Web Harvester","version":"0.1.0","description":"Clip web content to Markdown and save to your filesystem.","permissions":["activeTab","storage","scripting","contextMenus","commands","sidePanel","clipboardWrite"],"host_permissions":["<all_urls>"],"background":{"service_worker":"src/presentation/background/background.js","type":"module"},"action":{"default_popup":"src/presentation/popup/popup.html","default_icon":{"48":"icons/icon-48.png"}},"options_ui":{"page":"src/presentation/settings/settings.html","open_in_tab":true},"side_panel":{"default_path":"src/presentation/side-panel/side-panel.html"},"content_scripts":[{"matches":["http://*/*","https://*/*"],"js":["src/presentation/content/content.js"],"run_at":"document_idle"}],"icons":{"16":"icons/icon-16.png","48":"icons/icon-48.png","128":"icons/icon-128.png"},"commands":{"_execute_action":{"suggested_key":{"default":"Alt+Shift+D"},"description":"Open Web Harvester"}}}