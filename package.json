{
  "name": "web-harvester",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_BROWSER=chrome vite",
    "build:chrome": "vite build --mode production",
    "lint": "eslint src tests --no-error-on-unmatched-pattern --max-warnings 0",
    "lint:fix": "eslint src tests --no-error-on-unmatched-pattern --fix",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx,json,css}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx,json,css}\" \"tests/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest --config vitest.browser.config.ts run",
    "test:e2e": "pnpm build:chrome && playwright test",
    "test:coverage": "vitest run --coverage",
    "test:all": "pnpm test:coverage && pnpm test:browser && pnpm test:e2e",
    "knip": "knip",
    "jscpd": "jscpd",
    "size-limit": "size-limit",
    "license-checker": "license-checker",
    "jsdoc-check": "documentation lint src/**/*.ts",
    "madge": "madge",
    "audit:deps": "pnpm audit --json > audits/reports/$(date +%Y-%m-%d)/pnpm-audit.json",
    "audit:static": "eslint --format @microsoft/eslint-formatter-sarif src/ -o audits/reports/$(date +%Y-%m-%d)/eslint.sarif",
    "audit:coverage": "pnpm test:coverage -- --reporter=json --outputFile=audits/reports/$(date +%Y-%m-%d)/coverage.json",
    "audit:report": "mkdir -p audits/reports/$(date +%Y-%m-%d) && pnpm audit:deps && pnpm audit:static && pnpm audit:coverage && if [ -n \"$(ls -A audits/templates 2>/dev/null)\" ]; then cp -r audits/templates/* audits/reports/$(date +%Y-%m-%d)/; fi",
    "lint:manifest": "web-ext lint --source-dir dist/",
    "lint:dupes": "jscpd src/",
    "analyze": "vite build --mode production && npx rollup-plugin-visualizer dist/stats.html",
    "prepare": "husky"
  },
  "jscpd": {
    "threshold": 0,
    "minLines": 5,
    "minTokens": 50,
    "ignore": [
      "dist/**",
      "tests/**",
      "docs/**"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@formatjs/intl": "^3.1.8",
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "defuddle": "^0.18.1",
    "dompurify": "^3.4.2",
    "intl-messageformat": "^10.7.18",
    "inversify": "^6.2.2",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^11.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.40",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitest/browser": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "documentation": "^14.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-formatjs": "^5.4.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^2.0.4",
    "fake-indexeddb": "^5.0.2",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jscpd": "^4.0.9",
    "jsdom": "^25.0.1",
    "knip": "^5.88.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^15.5.2",
    "madge": "^7.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.4.2",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^2.1.9",
    "web-ext": "^8.10.0"
  }
}
